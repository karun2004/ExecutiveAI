# ============================================
# MACH-1 v3 — Environment Configuration
# Copy this to .env and fill in your keys
# ============================================

# --- API Keys ---
GROQ_API_KEY=your_groq_key_here
MISTRAL_API_KEY=your_mistral_key_here
GOOGLE_AI_KEY=your_google_ai_key_here

# --- Model Assignments ---
GROQ_MODEL=llama-3.3-70b-versatile
MISTRAL_CHAT_MODEL=mistral-large-latest
MISTRAL_CODE_MODEL=codestral-latest
OLLAMA_CHAT_MODEL=mistral:7b
OLLAMA_CODE_MODEL=qwen2.5-coder:7b
GOOGLE_MODEL=gemini-2.0-flash

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434

# --- Paths ---
MACH1_HOME=/home/cumpooter/mach-1
DATA_DIR=/home/cumpooter/mach-1/data
LOG_DIR=/home/cumpooter/mach-1/logs
BACKUP_DIR=/home/cumpooter/mach-1/backups

# --- Flask Dashboard ---
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_SECRET_KEY=change-this-to-a-random-string

# --- GitHub ---
GITHUB_TOKEN=your_github_token_here
GITHUB_USERNAME=your_github_username
GITHUB_DEFAULT_ORG=

# --- Notifications ---
NTFY_TOPIC=mach1-alerts
NTFY_SERVER=https://ntfy.sh

# --- Rate Limits (requests per day) ---
GROQ_RPD=1000
GOOGLE_RPD=250
MISTRAL_RPS=1

# --- Schedule ---
HEALTH_CHECK_HOUR=23
HEALTH_CHECK_MINUTE=0
BACKUP_HOUR=23
BACKUP_MINUTE=10
